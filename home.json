{
  "feature": "home_page_design",

  "description": "Diseñar una página de inicio espectacular, minimalista y altamente visual para el proyecto ATISBO. El home debe sentirse como la portada de un documental de viajes y ser el punto de entrada principal para explorar el proyecto Todo Chile en Bicicleta.",

  "design_concept": {
    "experience": "documental interactivo",
    "style": "minimalista, cinematográfico, emocional",
    "inspiration": [
      "Patagonia storytelling",
      "Apple product pages",
      "National Geographic digital",
      "Airbnb travel experiences"
    ]
  },

  "layout_structure": {

    "hero_section": {
      "type": "fullscreen",
      "height": "100vh",
      "background": "fotografía épica de Isabel en bicicleta",
      "overlay": "oscuro sutil para mejorar legibilidad",
      "elements": [
        "headline",
        "subheadline",
        "explore button"
      ],
      "headline_example": "Todo Chile en Bicicleta",
      "subheadline_example": "Una travesía para recorrer cada comuna del país sobre dos ruedas.",
      "cta": {
        "label": "Explorar el viaje",
        "link": "/mapa"
      }
    },

    "travel_progress_section": {
      "description": "Mostrar el progreso del proyecto con métricas visuales grandes.",
      "layout": "centered stats",
      "metrics": [
        "comunas recorridas",
        "regiones visitadas",
        "kilómetros recorridos",
        "días en ruta"
      ],
      "example": {
        "comunas": "143 / 346",
        "regiones": "9 / 16",
        "kilometros": "12,400 km",
        "dias": "520 días"
