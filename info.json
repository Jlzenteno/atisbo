    "project_tagline": "Todo Chile en Bicicleta",
    "description": "ATISBO es un proyecto documental de viajes donde Isabel, una viajera chilena, está recorriendo todas las comunas de Chile en bicicleta. El sitio web será la plataforma central para documentar el viaje, publicar bitácoras, fotografías, videos y mostrar el progreso del proyecto.",
    "reference_sites": {
      "current_site": "https://sites.google.com/view/atisbo",
      "instagram": "https://www.instagram.com/_atisbo"
    }
  },

  "legacy_data": {
    "description": "Existe una carpeta llamada 'info-web-atisbo' que contiene un proyecto antiguo en HTML con información extraída desde el sitio actual de Google Sites.",
    "purpose": "La IA debe analizar esta carpeta para reutilizar contenido existente como textos, estructura de páginas, información del proyecto y datos históricos.",
    "instructions": [
      "Analizar los archivos HTML dentro de la carpeta 'info-web-atisbo'.",
      "Extraer contenido útil como textos, bitácoras, secciones del proyecto y descripciones.",
      "Reorganizar esta información dentro de la nueva arquitectura del sitio.",
      "Optimizar los textos para SEO y storytelling.",
      "Eliminar elementos innecesarios o repetidos."
    ]
  },

  "goal": {
    "main_objective": "Crear una plataforma web moderna, minimalista y altamente visual para documentar el proyecto Todo Chile en Bicicleta.",
    "experience": "El sitio debe sentirse como un documental interactivo de viajes.",
    "future_goal": "Convertirse en una plataforma modelo para creadores de contenido de aventura, cicloviajeros e influencers de viajes."
  },

