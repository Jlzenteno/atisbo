{
  "regions": [
    {
      "id": "araucania",
      "name": "Región de la Araucanía",
      "slug": "araucania",
      "description": "La Región de La Araucanía se caracteriza por sus volcanes activos, lagos cristalinos, densos bosques de araucarias y la presencia viva de la cultura mapuche. Es una tierra de contrastes naturales y riqueza cultural.",
      "visited": true
    },
    {
      "id": "biobio",
      "name": "Región del Biobío",
      "slug": "biobio",
      "description": "La Región del Biobío, marcada por su fuerza natural y su identidad histórica, ha sido un hito clave en el proyecto. Desde la cordillera hasta la costa, cada kilómetro está cargado de memoria, resistencia y belleza diversa.",
      "visited": true
    },
    {
      "id": "de-aysen",
      "name": "Región de los Ríos",
      "slug": "de-aysen",
      "description": "La Región de Aysén del General Carlos Ibáñez del Campo es uno de los territorios más indómitos y sobrecogedores de Chile. Ubicada en plena Patagonia, es famosa por sus paisajes majestuosos de montañas, fiordos, glaciares y ríos cristalinos.",
      "visited": true
    },
    {
      "id": "de-los-lagos",
      "name": "Región de los Ríos",
      "slug": "de-los-lagos",
      "description": "La Región de Los Lagos es un territorio mágico del sur de Chile, conocido por sus imponentes volcanes, vastos lagos, canales, y una profunda cultura chilota. Con una diversidad geográfica que abarca desde los fiordos de Palena hasta los verdes campos de Osorno, recorrer esta región en bicicleta es adentrarse en un mundo lleno de historia, tradición y naturaleza.",
      "visited": true
    },
    {
      "id": "de-los-rios",
      "name": "Región de los Ríos",
      "slug": "de-los-rios",
      "description": "La Región de Los Ríos, con sus paisajes verdes y su red de ríos que atraviesan bosques templados lluviosos, ofrece una experiencia única para el cicloviaje. \n    Es un territorio lleno de vida, cultura mapuche, historia colonial y naturaleza prístina.",
      "visited": true
    },
    {
      "id": "de-magallanes",
      "name": "Región de Magallanes y de la Antártica Chilena",
      "slug": "de-magallanes",
      "description": "La Región de Magallanes y de la Antártica Chilena es el extremo más austral de Chile y del continente sudamericano. Sus paisajes sobrecogen por su inmensidad, con fiordos, glaciares, pampas infinitas y cielos que parecen no acabar.",
      "visited": true
    }
  ],
